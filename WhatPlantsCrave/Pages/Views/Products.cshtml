@page
@model WhatPlantsCrave.Pages.Views.ProductsModel
@{
    ViewData["Title"] = "Products";
}

<h1>@ViewData["Title"]</h1>

@if (Model.Products.Any())
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Product Number</th>
                <th>Color</th>
                <th>Standard Cost</th>
                <th>List Price</th>
                <th>Size</th>
                <th>Weight</th>
                <th>Sell Start Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Products)
            {
                <tr>
                    <td>@item.ProductId</td>
                    <td>@item.Name</td>
                    <td>@item.ProductNumber</td>
                    <td>@(string.IsNullOrEmpty(item.Color) ? "N/A" : item.Color)</td>
                    <td>$@item.StandardCost.ToString("F2")</td>
                    <td>$@item.ListPrice.ToString("F2")</td>
                    <td>@(string.IsNullOrEmpty(item.Size) ? "N/A" : item.Size)</td>
                    <td>@(item.Weight.HasValue ? item.Weight.Value.ToString("F2") + " lbs" : "N/A")</td>
                    <td>@item.SellStartDate.ToString("yyyy-MM-dd")</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">No products found.</div>
}
